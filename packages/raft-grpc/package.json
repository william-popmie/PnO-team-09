{
  "name": "@maboke123/raft-grpc",
  "version": "0.1.0",
  "description": "gRPC transport adapter for @maboke123/raft-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maboke123/raft-consensus-algorithm.git"
  },
  "bugs": {
    "url": "https://github.com/maboke123/raft-consensus-algorithm/issues"
  },
  "homepage": "https://github.com/maboke123/raft-consensus-algorithm#readme",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "proto"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0"
  },
  "peerDependencies": {
    "@maboke123/raft-core": ">=0.1.0"
  },
  "devDependencies": {
    "@maboke123/raft-core": "*",
    "@types/node": "25.2.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
